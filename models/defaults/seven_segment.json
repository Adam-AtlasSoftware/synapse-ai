{
  "name": "Seven-segment digit",
  "description": "Seven segment toggles (a–g, like a calculator display) → which digit 0-9 is lit. Digit recognition with labeled inputs, no grid yet.",
  "input_dim": 7,
  "layers": [
    {
      "type": "dense",
      "units": 12,
      "activation": "relu"
    },
    {
      "type": "dense",
      "units": 10,
      "activation": "softmax"
    }
  ],
  "io": {
